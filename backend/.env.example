# Django
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-generate-with-python-secrets
DEBUG=False
ALLOWED_HOSTS=.{{DOMAIN}}
BASE_DOMAIN={{DOMAIN}}

# Database
DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://{{DOMAIN}},https://app.{{DOMAIN}}

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend
RESEND_API_KEY=re_...
DEFAULT_FROM_EMAIL=noreply@{{DOMAIN}}

# Sentry
SENTRY_DSN=

# PostHog (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Feature flags
FEATURE_TEAMS=true
FEATURE_BILLING=true
FEATURE_NOTIFICATIONS=true

# App
APP_NAME=MyApp
ADMIN_URL=tacomate
FRONTEND_URL=https://{{DOMAIN}}
SUPPORT_EMAIL=support@{{DOMAIN}}

# Auth cookie domain
# Uncomment for production — the leading dot shares the cookie across all tenant
# subdomains (e.g. acme.{{DOMAIN}}, corp.{{DOMAIN}}). Leave commented out in development.
# AUTH_COOKIE_DOMAIN=.{{DOMAIN}}
