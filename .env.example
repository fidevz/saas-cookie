# ─── Docker Compose ────────────────────────────────────────────────────────
POSTGRES_DB=saas_boilerplate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ─── Frontend (build args) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
