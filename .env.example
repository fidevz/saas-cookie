# ─── Docker Compose ────────────────────────────────────────────────────────
POSTGRES_DB=saas_boilerplate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<REPLACE_WITH_STRONG_RANDOM_PASSWORD>   # e.g. openssl rand -base64 32

# ─── Frontend (build args) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Redis ─────────────────────────────────────────────────────────────────
# Must match REDIS_URL password in backend/.env: redis://:password@redis:6379/0
REDIS_PASSWORD=<REPLACE_WITH_STRONG_RANDOM_PASSWORD>       # e.g. openssl rand -base64 32

# ─── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=<REPLACE_WITH_RANDOM_ACCESS_KEY>           # e.g. openssl rand -hex 16
MINIO_ROOT_PASSWORD=<REPLACE_WITH_STRONG_RANDOM_PASSWORD>  # e.g. openssl rand -base64 32
MINIO_BUCKET=media

# ─── Backend (.env is loaded from backend/.env) ────────────────────────────
# Copy backend/.env.example → backend/.env and fill it in separately
