# In development, set NEXT_PUBLIC_API_URL=/api/v1 and INTERNAL_API_URL=http://localhost:8000
# so all API requests are proxied through Next.js (same-origin → cookies work across subdomains).
# In production, set NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1 and omit INTERNAL_API_URL.
NEXT_PUBLIC_API_URL=/api/v1
INTERNAL_API_URL=http://localhost:8000

NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=MyApp
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_BASE_DOMAIN=localhost
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
